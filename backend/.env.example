# App
ENV=development
DEBUG=true

# Security - generate with: openssl rand -hex 32
SECRET_KEY=replace_with_a_long_random_secret

# CORS - comma-separated origins are parsed as a JSON array by pydantic-settings
CORS_ORIGINS=["http://localhost:3000"]

# Database
DATABASE_URL=postgresql+asyncpg://smiley:smiley@postgres:5432/smileygpt

# Redis
REDIS_URL=redis://redis:6379/0
RATE_LIMIT_PER_MINUTE=60

# LLM provider (OpenAI-compatible)
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_DEFAULT_MODEL=gpt-4o-mini
LLM_VISION_MODEL=gpt-4o-mini
AVAILABLE_MODELS=["gpt-4o-mini","gpt-4o","gpt-4.1-mini"]

# Memory
CHROMA_PERSIST_DIR=/data/chroma
MEMORY_TOP_K=5

# Uploads
UPLOAD_DIR=/data/uploads
MAX_UPLOAD_MB=20

# Admin - emails listed here are auto-promoted to admin on registration
ADMIN_EMAILS=["admin@smileygpt.dev"]
